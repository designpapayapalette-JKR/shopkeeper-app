{
  "expo": {
    "name": "Shopkeeper",
    "slug": "shopkeeper-app",
    "scheme": "shopkeeper",
    "version": "0.1.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#FAF9F6",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.papayapalette.shopkeeper"
    },
    "android": {
      "package": "com.papayapalette.shopkeeper",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      "expo-font",
      "@config-plugins/react-native-webrtc",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": false,
            "enableShrinkResourcesInReleaseBuilds": false,
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a9c628d7-7fd8-481b-8076-a32a0ce72a68"
      }
    },
    "owner": "papayapalette"
  }
}
